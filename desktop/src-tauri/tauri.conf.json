{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Webwing",
  "version": "0.1.0",
  "identifier": "com.webwing.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Webwing",
        "width": 1360,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/node"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../server.mjs": "server.mjs",
      "../../package.json": "package.json",
      "../../src": "src",
      "../../public": "public",
      "../../node_modules": "node_modules"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "headerImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "bannerPath": "installer-assets/wix-banner.bmp",
        "dialogImagePath": "installer-assets/wix-dialog.bmp"
      }
    }
  }
}
